{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"],
      "env": [
        "NEXT_PUBLIC_SITE_URL",
        "NEXT_PUBLIC_TURNSTILE_SITE_KEY",
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY",
        "APPLE_DEVELOPER_TEAM_ID",
        "APPLE_APP_STORE_BUNDLE_ID",
        "APPLE_MAPS_WEB_TEAM_ID",
        "APPLE_MAPS_WEB_MAPS_ID",
        "APPLE_MAPS_WEB_KEY_ID",
        "APPLE_MAPS_WEB_PRIVATE_KEY",
        "APPLE_MAPS_WEB_PRIVATE_KEY_PATH",
        "APPLE_MAPS_WEB_ALLOWED_ORIGINS",
        "APPLE_SIGN_IN_TEAM_ID",
        "APPLE_SIGN_IN_KEY_ID",
        "APPLE_SIGN_IN_PRIVATE_KEY",
        "APPLE_SIGN_IN_PRIVATE_KEY_PATH",
        "MOBILE_APP_LINK_HOSTS",
        "JEP_FORCE_PUBLIC_VISIBLE"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": [".eslintcache"]
    },
    "type-check": {
      "dependsOn": ["^type-check"],
      "outputs": [".next/cache/tsc/**", "dist/**/*.d.ts", "dist/**/*.d.ts.map"]
    },
    "type-check:ci": {
      "dependsOn": ["^type-check:ci"],
      "outputs": [".next/cache/tsc/**"]
    }
  }
}
