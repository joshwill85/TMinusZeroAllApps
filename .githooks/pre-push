#!/usr/bin/env bash
set -euo pipefail

remote_name="${1:-}"
remote_url="${2:-}"

if [[ "${ALLOW_MAIN_PUSH:-}" == "1" ]]; then
  exit 0
fi

blocked=0
while read -r local_ref local_sha remote_ref remote_sha; do
  case "$remote_ref" in
    refs/heads/main|refs/heads/master)
      {
        echo "ERROR: direct pushes to '${remote_ref#refs/heads/}' are blocked."
        echo "Use a feature branch + PR, or override with:"
        echo "  ALLOW_MAIN_PUSH=1 git push ${remote_name:-origin} HEAD:${remote_ref#refs/heads/}"
        echo "  (or) git push --no-verify"
      } >&2
      blocked=1
      ;;
  esac
done

exit "$blocked"

