#!/usr/bin/env bash
set -euo pipefail

deny=()

while IFS= read -r -d '' path; do
  case "$path" in
    .git/*|.git.backup*|.git-meta/*|.vercel/*)
      deny+=("$path")
      continue
      ;;
    .env|.env.*)
      if [[ "$path" != ".env.example" ]]; then
        deny+=("$path")
        continue
      fi
      ;;
  esac

  case "$path" in
    id_rsa|id_rsa.pub|id_ed25519|id_ed25519.pub|*.pem|*.p12|*.pfx)
      deny+=("$path")
      ;;
  esac
done < <(git diff --cached --name-only -z)

if (( ${#deny[@]} > 0 )); then
  {
    echo "ERROR: refusing to commit sensitive/internal files:"
    printf ' - %s\n' "${deny[@]}"
    echo
    echo "If intentional, bypass with: git commit --no-verify"
  } >&2
  exit 1
fi

# Lightweight content scan for private key blocks (staged content only).
while IFS= read -r -d '' path; do
  if ! git cat-file -e ":$path" 2>/dev/null; then
    continue
  fi

  size="$(git cat-file -s ":$path" 2>/dev/null || echo 0)"
  if [[ "$size" -gt 1048576 ]]; then
    continue
  fi

  if git show ":$path" | LC_ALL=C grep -Eq 'BEGIN (OPENSSH|RSA|EC)? ?PRIVATE KEY|BEGIN PGP PRIVATE KEY BLOCK'; then
    {
      echo "ERROR: staged file appears to contain a private key block: $path"
      echo
      echo "If this is truly intentional, bypass with: git commit --no-verify"
    } >&2
    exit 1
  fi
done < <(git diff --cached --name-only -z)

