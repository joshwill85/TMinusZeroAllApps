{
  "cli": {
    "version": ">= 16.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "EXPO_PUBLIC_MOBILE_APPLE_AUTH_ENABLED": "1"
      }
    },
    "preview": {
      "distribution": "internal",
      "autoIncrement": true,
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_MOBILE_APPLE_AUTH_ENABLED": "1"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_MOBILE_APPLE_AUTH_ENABLED": "1"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
