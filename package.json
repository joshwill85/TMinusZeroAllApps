{
  "name": "tminuszero",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  },
  "volta": {
    "node": "20.19.6",
    "npm": "10.8.2"
  },
  "scripts": {
    "preinstall": "node scripts/check-toolchain.cjs",
    "doctor": "node scripts/doctor-toolchain.cjs",
    "auth:apple:client-secret": "node scripts/generate-apple-client-secret.mjs",
    "check:three-platform:boundaries": "node scripts/three-platform-boundary-check.cjs",
    "dev": "npm run dev --workspace @tminuszero/web",
    "dev:mobile": "npm run dev --workspace @tminuszero/mobile",
    "ios": "npm run ios --workspace @tminuszero/mobile",
    "android": "npm run android --workspace @tminuszero/mobile",
    "mobile:prebuild": "npm run prebuild --workspace @tminuszero/mobile",
    "mobile:e2e:build:ios": "npm run e2e:build:ios --workspace @tminuszero/mobile",
    "mobile:e2e:test:ios": "npm run e2e:test:ios --workspace @tminuszero/mobile",
    "mobile:e2e:test:ios:artifacts": "npm run e2e:test:ios:artifacts --workspace @tminuszero/mobile",
    "mobile:e2e:build:android": "npm run e2e:build:android --workspace @tminuszero/mobile",
    "mobile:e2e:test:android": "npm run e2e:test:android --workspace @tminuszero/mobile",
    "mobile:e2e:acceptance:ios": "npm run e2e:acceptance:ios --workspace @tminuszero/mobile",
    "mobile:e2e:acceptance:android": "npm run e2e:acceptance:android --workspace @tminuszero/mobile",
    "mobile:e2e:acceptance": "npm run mobile:e2e:acceptance:android && npm run mobile:e2e:acceptance:ios",
    "build": "turbo run build --filter=@tminuszero/web",
    "build:web": "npm run build --workspace @tminuszero/web",
    "start": "npm run start --workspace @tminuszero/web",
    "start:web": "npm run start --workspace @tminuszero/web",
    "lint": "turbo run lint --filter=@tminuszero/web",
    "lint:workspaces": "turbo run lint",
    "lint:diag": "bash scripts/diagnose-lint.sh",
    "type-check": "turbo run type-check --filter=@tminuszero/web",
    "type-check:all": "turbo run type-check",
    "type-check:ci": "turbo run type-check:ci --filter=@tminuszero/web",
    "type-check:mobile": "npm run type-check --workspace @tminuszero/mobile",
    "type-check:diag": "bash scripts/diagnose-typecheck.sh",
    "check": "npm run lint && npm run type-check && npm run test:public-cache",
    "test:artemis-data": "ts-node --project tsconfig.scripts.json --transpile-only scripts/artemis-data-audit.ts",
    "qa:artemis": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/artemis-qa-scan.ts",
    "audit:artemis-sources": "ts-node --project tsconfig.scripts.json --transpile-only scripts/artemis-source-option-audit.ts",
    "audit:data-attribution": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/data-attribution-audit.ts",
    "audit:faq": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/faq-audit.ts",
    "audit:blue-origin": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/audit-blue-origin.ts",
    "audit:usaspending:hubs": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/usaspending-hub-audit.ts --mode=report",
    "backfill:usaspending:hubs": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/usaspending-hub-audit.ts --mode=write",
    "check:prod": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/prod-readiness.ts",
    "check:stripe-webhook": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/stripe-webhook-check.ts",
    "check:billing-readiness": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/billing-readiness.ts",
    "test:smoke": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/smoke-tests.ts",
    "test:blue-origin-dossier": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/blue-origin-dossier-smoke.ts",
    "test:spacex-hub": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/spacex-program-hub-smoke.ts",
    "test:token-feeds": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/token-feeds-smoke.ts",
    "test:public-cache": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/public-cache-guard.ts",
    "test:v1-contracts": "TS_NODE_TRANSPILE_ONLY=1 node --loader ts-node/esm scripts/v1-contracts-smoke.mts",
    "test:mobile-query-guard": "TS_NODE_TRANSPILE_ONLY=1 node --loader ts-node/esm scripts/mobile-query-guard.mts",
    "test:launch-refresh-guard": "TS_NODE_TRANSPILE_ONLY=1 node --loader ts-node/esm scripts/launch-refresh-guard.mts",
    "test:gating-alignment-guard": "TS_NODE_TRANSPILE_ONLY=1 node --loader ts-node/esm scripts/gating-alignment-guard.mts",
    "test:mobile-security-guard": "TS_NODE_TRANSPILE_ONLY=1 node --loader ts-node/esm scripts/mobile-security-guard.mts",
    "test:shared-domain": "TS_NODE_TRANSPILE_ONLY=1 node --experimental-specifier-resolution=node --loader ts-node/esm scripts/shared-domain-smoke.mts",
    "test:phase3-web-guard": "TS_NODE_TRANSPILE_ONLY=1 node --loader ts-node/esm scripts/phase3-web-closeout-guard.mts",
    "test:web-regression": "TS_NODE_TRANSPILE_ONLY=1 node --loader ts-node/esm scripts/web-regression-smoke.mts",
    "test:billing-regression": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/billing-regression-smoke.ts",
    "test:three-platform:hot-path": "TS_NODE_TRANSPILE_ONLY=1 node --loader ts-node/esm scripts/three-platform-hot-path-guard.mts",
    "test:rate-limit-smoke": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/rate-limit-smoke.ts",
    "seed:three-platform:local": "ts-node --project tsconfig.scripts.json --transpile-only scripts/three-platform-local-acceptance-seed.ts",
    "baseline:three-platform": "ts-node --project tsconfig.scripts.json --transpile-only scripts/three-platform-baseline-capture.ts",
    "acceptance:preflight": "ts-node --project tsconfig.scripts.json --transpile-only scripts/three-platform-acceptance-preflight.ts",
    "acceptance:local": "ts-node --project tsconfig.scripts.json --transpile-only scripts/three-platform-local-acceptance.ts",
    "test:social-posts": "ts-node --project tsconfig.scripts.json --transpile-only scripts/social-posts-guard.ts",
    "test:seo": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/seo-tests.ts",
    "test:usaspending-hubs": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/usaspending-hub-audit-test.ts",
    "jep:calibration": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/jep-calibration-report.ts",
    "jep:outcomes:import": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/jep-outcome-import.ts",
    "analyze:io-top10": "ts-node --project tsconfig.scripts.json --transpile-only scripts/prod-io-top10-runs.ts",
    "analyze:sam-baseline": "ts-node --project tsconfig.scripts.json --transpile-only scripts/sam-baseline-report.ts",
    "perf:ttfb": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/ttfb-bench.ts",
    "export:billing-evidence": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/billing-evidence-export.ts",
    "format": "prettier --write .",
    "trajectory:coverage": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/ar-trajectory-coverage.ts",
    "trajectory:partner-feed:import": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/trajectory-partner-feed-import.ts",
    "trajectory:coverage:check": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/ar-trajectory-coverage-check.ts",
    "trajectory:replay:family-check": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/ar-trajectory-family-replay-check.ts",
    "trajectory:refresh:jobs": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/ar-trajectory-refresh-jobs.ts",
    "trajectory:lock-on:field-report": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/ar-lock-on-field-report.ts",
    "trajectory:kpi:check": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/ar-trajectory-kpi-check.ts",
    "trajectory:kpi:history": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/ar-trajectory-kpi-history.ts",
    "trajectory:replay-bench": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/ar-trajectory-replay-bench.ts",
    "trajectory:replay-gate": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/ar-trajectory-replay-gate.ts",
    "check:https": "ts-node --project tsconfig.scripts.json --transpile-only scripts/check-https-subdomains.ts",
    "backfill:blue-origin:launch-details": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/blue-origin-launch-details-backfill.ts",
    "audit:spacex:booster-joins": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/spacex-booster-joins-backfill.ts --mode=report",
    "backfill:spacex:booster-joins": "ts-node --project tsconfig.scripts.json --transpile-only -r tsconfig-paths/register scripts/spacex-booster-joins-backfill.ts --mode=backfill --write"
  },
  "dependencies": {
    "@apple/app-store-server-library": "^2.0.0",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@stripe/react-stripe-js": "^2.9.0",
    "@stripe/stripe-js": "^4.10.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.43.1",
    "clsx": "^2.1.0",
    "date-fns": "^2.30.0",
    "date-fns-tz": "^2.0.0",
    "dotenv": "^16.3.1",
    "framer-motion": "^12.24.0",
    "google-auth-library": "^10.6.1",
    "next": "^14.2.35",
    "next-safe-action": "^5.0.2",
    "pdfjs-dist": "^4.0.379",
    "pg": "^8.11.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-globe.gl": "^2.37.0",
    "sharp": "^0.33.2",
    "stripe": "^14.6.0",
    "three": "^0.182.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "20.19.27",
    "@types/pg": "^8.16.0",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.17",
    "autoprefixer": "^10.4.16",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.4.32",
    "prettier": "^3.1.1",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "turbo": "2.8.14",
    "typescript": "5.9.3"
  },
  "overrides": {
    "@next/eslint-plugin-next": {
      "glob": "10.5.0"
    }
  }
}
